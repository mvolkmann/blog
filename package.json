{
  "name": "blog",
  "version": "1.1.1",
  "author": "R. Mark Volkmann",
  "bugs": {
    "url": "https://github.com/mvolkmann/blog/issues"
  },
  "description": "Mark Volkmann's blog using Astro",
  "homepage": "https://github.com/mvolkmann/blog#readme",
  "keywords": [
    "blog"
  ],
  "license": "MIT",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvolkmann/blog.git"
  },
  "scripts": {
    "add": "git add .",
    "all": "run-s build add commit push deploy",
    "build": "npm run prepare:public && npm run sass && astro build",
    "clean": "rm -rf _site public/assets public/js",
    "commit": "git commit -av",
    "deploy": "gh-pages -d _site",
    "dev": "npm run prepare:public && npm-run-all --parallel watch:sass watch:astro",
    "format": "prettier --write 'app/**/*.{astro,ts}' 'src/**/*.{css,html,js}' 'scripts/**/*.mjs'",
    "lint": "oxlint",
    "lint-old": "eslint --fix --quiet src --ext .js",
    "prepare:public": "node scripts/prepare-public.mjs",
    "preview": "astro preview",
    "push": "git push origin master",
    "reinstall": "rm -rf node_modules package-lock.json && npm install",
    "sass": "sass --style=compressed src/sass:public/assets",
    "serve": "npm run dev",
    "watch:astro": "astro dev",
    "watch:sass": "npm run sass -- --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^1.0.2",
    "@11ty/eleventy-navigation": "^0.3.5",
    "@11ty/eleventy-plugin-inclusive-language": "^1.0.3",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.2.0",
    "@mightyplow/eleventy-plugin-cache-buster": "^1.1.3",
    "@types/prismjs": "^1.26.6",
    "acorn": "^8.8.0",
    "eleventy-plugin-nesting-toc": "^1.3.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "gh-pages": "^4.0.0",
    "html-minifier": "^4.0.0",
    "markdown-it-anchor": "^8.6.5",
    "markdown-it-footnote": "^3.0.3",
    "markdown-it-mathjax": "^2.0.0",
    "markdown-it-sub": "^1.0.0",
    "markdown-it-sup": "^1.0.0",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.9.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.55.0"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^5.1.1",
    "@parcel/watcher": "^2.5.1",
    "astro": "^6.0.7",
    "gray-matter": "^4.0.3",
    "markdown-it": "^13.0.1",
    "prismjs": "^1.30.0"
  }
}
