---
import NavTree from '../components/NavTree.astro';
import type {NavNode} from '../lib/content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  css?: string;
  currentPath?: string;
  hasCodeBlocks?: boolean;
  hasMath?: boolean;
  navTree: NavNode[];
  title?: string;
}

const {
  css,
  currentPath = '',
  hasCodeBlocks = false,
  hasMath = false,
  navTree,
  title
} = Astro.props;
---

<BaseLayout
  css="/blog/assets/topic.css"
  hasCodeBlocks={hasCodeBlocks}
  hasMath={hasMath}
  title={title}
>
  {css ? <link rel="stylesheet" href={css} slot="head" /> : null}
  <script is:inline src="/blog/js/topics.js"></script>

  <nav>
    <NavTree currentPath={currentPath} items={navTree} topLevel={true} />
  </nav>

  <section class="topic-background">
    <section class="topic-content">
      <button
        id="print-btn"
        onclick="print()"
        style="position: absolute; right: 20px"
      >
        Print
      </button>
      <section class="topic-page">
        <slot />
      </section>
    </section>
  </section>
</BaseLayout>
