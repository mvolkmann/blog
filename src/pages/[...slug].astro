---
import {render} from 'astro:content';
import TopicsLayout from '../layouts/TopicsLayout.astro';
import TopicLayout from '../layouts/TopicLayout.astro';
import {
  buildTocHtml,
  getEntryTitle,
  getNavTree,
  getTopicEntries,
  hasCodeContent,
  hasMathContent,
  toRoutePath
} from '../lib/content';

export async function getStaticPaths() {
  const entries = await getTopicEntries();

  return entries.map(entry => ({
    params: {slug: toRoutePath(entry)},
    props: {entry}
  }));
}

const {entry} = Astro.props;
const headingText = `${getEntryTitle(entry)}${entry.data.extraTitle ? ` ${entry.data.extraTitle}` : ''}`;
const hasCodeBlocks = hasCodeContent(entry);
const hasMath = hasMathContent(entry);
const navTree = await getNavTree();
const {Content, headings} = await render(entry);
const tocHtml = buildTocHtml(headings);
const currentPath = `/blog/${toRoutePath(entry)}/`;
---

<TopicsLayout
  css={entry.data.css}
  currentPath={currentPath}
  hasCodeBlocks={hasCodeBlocks}
  hasMath={hasMath}
  navTree={navTree}
  title={headingText}
>
  <TopicLayout Content={Content} headingText={headingText} tocHtml={tocHtml} />
</TopicsLayout>
