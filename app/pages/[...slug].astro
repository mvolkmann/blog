---
import TopicLayout from '../layouts/TopicLayout.astro';
import {getTopicPages} from '../lib/content';

export function getStaticPaths() {
  return getTopicPages().map(page => ({
    params: {slug: page.slug.join('/')},
    props: {page}
  }));
}

const {page} = Astro.props;
---

<TopicLayout page={page} />
